<div class="size-guide-modal" id="size-guide-modal" role="dialog" aria-modal="true" aria-label="Maattabel" aria-hidden="true">
  <div class="size-guide-modal__overlay"></div>
  <div class="size-guide-modal__content">
    <button class="size-guide-modal__close" aria-label="Maattabel sluiten">
      {%- render 'icon', icon: 'close' -%}
    </button>

    <h2 style="font-size:1.25rem;font-weight:700;margin-bottom:var(--space-lg);">Maattabel</h2>

    <div style="display:flex;gap:.5rem;margin-bottom:var(--space-md);">
      <button class="btn btn-sm btn-primary" data-size-type="eu">EU</button>
      <button class="btn btn-sm btn-outline" data-size-type="us">US</button>
      <button class="btn btn-sm btn-outline" data-size-type="uk">UK</button>
    </div>

    <div style="overflow-x:auto;">
      <table class="size-table" aria-label="Schoenmaten">
        <thead>
          <tr>
            <th scope="col">EU</th>
            <th scope="col">US (Heren)</th>
            <th scope="col">US (Dames)</th>
            <th scope="col">UK</th>
            <th scope="col">CM</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>36</td><td>4</td><td>5.5</td><td>3.5</td><td>22.5</td></tr>
          <tr><td>37</td><td>4.5</td><td>6</td><td>4</td><td>23</td></tr>
          <tr><td>38</td><td>5.5</td><td>7</td><td>5</td><td>24</td></tr>
          <tr><td>39</td><td>6</td><td>7.5</td><td>5.5</td><td>24.5</td></tr>
          <tr><td>40</td><td>6.5</td><td>8</td><td>6</td><td>25</td></tr>
          <tr><td>41</td><td>7.5</td><td>9</td><td>7</td><td>26</td></tr>
          <tr><td>42</td><td>8</td><td>9.5</td><td>7.5</td><td>26.5</td></tr>
          <tr><td>43</td><td>9</td><td>10.5</td><td>8.5</td><td>27.5</td></tr>
          <tr><td>44</td><td>10</td><td>11.5</td><td>9.5</td><td>28</td></tr>
          <tr><td>45</td><td>11</td><td>12.5</td><td>10.5</td><td>29</td></tr>
          <tr><td>46</td><td>12</td><td>13</td><td>11</td><td>30</td></tr>
          <tr><td>47</td><td>13</td><td>14</td><td>12</td><td>31</td></tr>
          <tr><td>48</td><td>14</td><td>15</td><td>13</td><td>32</td></tr>
        </tbody>
      </table>
    </div>

    <div style="margin-top:var(--space-lg);padding:var(--space-md);background:var(--color-bg-alt);border-radius:var(--radius-lg);">
      <h3 style="font-size:.875rem;font-weight:700;margin-bottom:.75rem;">📏 Hoe meet je je voet?</h3>
      <ol style="padding-left:1.25rem;font-size:.875rem;color:var(--color-mid);display:flex;flex-direction:column;gap:.5rem;line-height:1.6;">
        <li>Ga staan op een vel papier en teken je voet na</li>
        <li>Meet de langste afstand van hiel tot grote teen in centimeters</li>
        <li>Gebruik de tabel om je correcte maat te vinden</li>
        <li>Twijfel je? Kies de grotere maat</li>
      </ol>
    </div>
  </div>
</div>
