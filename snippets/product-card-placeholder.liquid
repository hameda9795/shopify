<article class="product-card">
  <div class="product-card__media" style="aspect-ratio:3/4;border-radius:var(--radius-lg);background:var(--color-bg-alt);overflow:hidden;">
    {{ 'product-' | append: index | placeholder_svg_tag: 'placeholder-svg' }}
  </div>
  <div style="margin-top:1rem;display:flex;flex-direction:column;gap:.5rem;">
    <div class="skeleton" style="height:12px;width:60px;"></div>
    <div class="skeleton" style="height:16px;width:80%;"></div>
    <div class="skeleton" style="height:18px;width:40%;"></div>
  </div>
</article>
