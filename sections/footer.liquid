<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="site-footer__grid">

      {%- comment -%} Brand column {%- endcomment -%}
      <div>
        <div class="site-header__logo-text" style="color:var(--color-white);font-size:1.5rem;">
          {{ shop.name | upcase }}
        </div>
        <p class="site-footer__brand-text">{{ section.settings.tagline | default: 'Premium sportschoenen voor elke loper. Jouw perfecte schoen, één stap verwijderd.' }}</p>
        <div class="site-footer__socials">
          {% if section.settings.instagram != blank %}
            <a href="{{ section.settings.instagram }}" class="site-footer__social" aria-label="Instagram" rel="noopener noreferrer" target="_blank">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
              </svg>
            </a>
          {% endif %}
          {% if section.settings.facebook != blank %}
            <a href="{{ section.settings.facebook }}" class="site-footer__social" aria-label="Facebook" rel="noopener noreferrer" target="_blank">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
            </a>
          {% endif %}
          {% if section.settings.tiktok != blank %}
            <a href="{{ section.settings.tiktok }}" class="site-footer__social" aria-label="TikTok" rel="noopener noreferrer" target="_blank">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.95a8.18 8.18 0 0 0 4.78 1.52V7.01a4.85 4.85 0 0 1-1.01-.32z"/>
              </svg>
            </a>
          {% endif %}
          {% if section.settings.youtube != blank %}
            <a href="{{ section.settings.youtube }}" class="site-footer__social" aria-label="YouTube" rel="noopener noreferrer" target="_blank">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/>
              </svg>
            </a>
          {% endif %}
        </div>
      </div>

      {%- comment -%} Navigation columns {%- endcomment -%}
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'link_list' %}
            <div {{ block.shopify_attributes }}>
              <h3 class="site-footer__heading">{{ block.settings.heading }}</h3>
              <ul class="site-footer__links" role="list">
                {% for link in linklists[block.settings.menu].links %}
                  <li><a href="{{ link.url }}" class="site-footer__link">{{ link.title }}</a></li>
                {% endfor %}
              </ul>
            </div>
          {% when 'contact' %}
            <div {{ block.shopify_attributes }}>
              <h3 class="site-footer__heading">{{ block.settings.heading | default: 'Contact' }}</h3>
              <div class="site-footer__links">
                {% if block.settings.email != blank %}
                  <a href="mailto:{{ block.settings.email }}" class="site-footer__link">{{ block.settings.email }}</a>
                {% endif %}
                {% if block.settings.phone != blank %}
                  <a href="tel:{{ block.settings.phone | remove: ' ' }}" class="site-footer__link">{{ block.settings.phone }}</a>
                {% endif %}
                {% if block.settings.address != blank %}
                  <address style="font-style:normal;" class="site-footer__link">{{ block.settings.address }}</address>
                {% endif %}
                {% if block.settings.hours != blank %}
                  <p class="site-footer__link" style="margin-top:.5rem;">{{ block.settings.hours }}</p>
                {% endif %}
              </div>
            </div>
        {% endcase %}
      {% endfor %}

    </div>
  </div>

  <div class="site-footer__bottom">
    <div class="container" style="display:flex;flex-direction:column;gap:1rem;align-items:center;text-align:center;">
      <div style="display:flex;flex-direction:column;gap:1rem;align-items:center;width:100%;">
        <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Alle rechten voorbehouden.</p>
        <div style="display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;">
          {% if section.settings.privacy_policy != blank %}
            <a href="{{ section.settings.privacy_policy }}" class="site-footer__link" style="color:rgba(255,255,255,.3);">Privacybeleid</a>
          {% endif %}
          {% if section.settings.terms != blank %}
            <a href="{{ section.settings.terms }}" class="site-footer__link" style="color:rgba(255,255,255,.3);">Algemene voorwaarden</a>
          {% endif %}
          <a href="{{ routes.root_url }}pages/cookie-beleid" class="site-footer__link" style="color:rgba(255,255,255,.3);">Cookiebeleid</a>
        </div>
      </div>
      <div class="site-footer__payment-icons" aria-label="Betaalmethoden">
        <div class="payment-icon">iDEAL</div>
        <div class="payment-icon">Visa</div>
        <div class="payment-icon">MC</div>
        <div class="payment-icon">PayPal</div>
        <div class="payment-icon">Klarna</div>
        <div class="payment-icon">Bancontact</div>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "class": "footer-section",
  "settings": [
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Merkbeschrijving",
      "default": "Premium sportschoenen voor elke loper. Jouw perfecte schoen, één stap verwijderd."
    },
    {
      "type": "header",
      "content": "Sociale media"
    },
    {
      "type": "url",
      "id": "instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "tiktok",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "youtube",
      "label": "YouTube URL"
    },
    {
      "type": "header",
      "content": "Juridische links"
    },
    {
      "type": "url",
      "id": "privacy_policy",
      "label": "Privacybeleid URL"
    },
    {
      "type": "url",
      "id": "terms",
      "label": "Algemene voorwaarden URL"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Linkkolom",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Kolomtitel",
          "default": "Navigatie"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "contact",
      "name": "Contactgegevens",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Kolomtitel",
          "default": "Contact"
        },
        {
          "type": "text",
          "id": "email",
          "label": "E-mailadres",
          "default": "info@stride.nl"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Telefoonnummer"
        },
        {
          "type": "textarea",
          "id": "address",
          "label": "Adres"
        },
        {
          "type": "text",
          "id": "hours",
          "label": "Openingstijden",
          "default": "Ma–Vr: 9:00–17:30"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        {
          "type": "link_list",
          "settings": {
            "heading": "Collecties",
            "menu": "footer-collections"
          }
        },
        {
          "type": "link_list",
          "settings": {
            "heading": "Service",
            "menu": "footer-service"
          }
        },
        {
          "type": "contact",
          "settings": {
            "heading": "Contact",
            "email": "info@stride.nl",
            "hours": "Ma–Vr: 9:00–17:30"
          }
        }
      ]
    }
  ]
}
{% endschema %}
